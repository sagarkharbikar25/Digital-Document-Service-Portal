# JDCOEM Digital Document Service Portal
# Git Ignore Rules

# Environments
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Storage (Keep folders but ignore contents)
storage/uploads/**/*
!storage/uploads/.gitkeep
storage/logs/**/*
!storage/logs/.gitkeep

# Composer
vendor/

# OS Files
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Temporary files
*.tmp
*.log

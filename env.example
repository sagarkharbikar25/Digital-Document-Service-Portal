# ============================================================
# DIGITAL DOCUMENT SERVICE PORTAL - ENVIRONMENT EXAMPLE
# ============================================================
# Rename this file to .env and fill in your actual credentials.
# ============================================================

# APP SETTINGS
APP_NAME="Digital Document Service Portal"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com/public
APP_TIMEZONE=Asia/Kolkata

# DATABASE (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db_name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_pass

# MAIL / SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password
MAIL_FROM_ADDRESS=your_email@gmail.com
MAIL_FROM_NAME="JDCOEM Digital Document Portal"

# STORAGE PATHS (relative to project root)
# Note: Keep these as is unless you change folder structure
STORAGE_PATH=storage
UPLOAD_PATH=storage/uploads
